@model IEnumerable<ApplicationUsers>

@{
    ViewBag.PageTitle = "User Managment";
    ViewBag.CardTitle = "View User";

}




<table class="table table-hover" width="100%">
    <tr>
        <td>Name</td>
        <td>Email</td>
        <td>PhoneNumber</td>
        <td>Options</td>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Email</td>
            <td>@item.PhoneNumber</td>
            <td>

                @if (item.LockoutEnd == null | item.LockoutEnd < DateTime.Now)
                {

                    <a asp-action="LockUnLock" asp-controller="Users" asp-route-id="@item.Id" class="btn btn-success">

                        <i class="fas fa-lock-open"></i>
                    </a>
                }
                else
                {

                    <a asp-action="LockUnLock" asp-controller="Users" asp-route-id="@item.Id" class="btn btn-danger">

                        <i class="fas fa-lock"></i>
                    </a>
                }





                <a asp-action="Delete" asp-controller="Category" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>

            </td>
        </tr>
    }


</table>

<div style="padding-bottom: 20px;">
    <a href="/Identity/Account/Register" class="btn btn-warning">Create New User</a>
</div>