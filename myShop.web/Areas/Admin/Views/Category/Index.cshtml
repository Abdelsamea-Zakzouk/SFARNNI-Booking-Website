@model IEnumerable<Category> 


@{
    ViewBag.PageTitle = "Category Managment" ;
    ViewBag.CardTitle = "View Category" ;
    Layout =  "~/Views/Shared/_DashBoard.cshtml";
}




<table class="table table-hover" width = "100%" >
    <tr>
        <td>Name</td>
        <td>Description</td>
        <td>Date Card</td>
        <td>Options</td>
    </tr>
 
        @foreach(var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Date</td>
                <td>
                    <a asp-action="Edit" asp-controller="Category" asp-route-id="@item.Id" class="btn btn-success">Edit</a>

                    <a asp-action="Delete" asp-controller="Category" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>

                </td>
            </tr>   
        }
   

</table>

<div  style="padding-bottom: 20px;">
    <a asp-action="Create" asp-controller="Category" class="btn btn-warning">Create Categort</a>
</div>