@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-dark text-white text-center">
                    <h3 class="card-title mb-0">@ViewData["Title"]</h3>
                    <p class="mt-2">Sign in to your account</p>
                </div>
                <div class="card-body">
                    <form id="account" method="post" class="p-3">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" aria-required="true" />
                            <label asp-for="Input.Email"><i class="bi bi-envelope me-2"></i>Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.Password" type="password" class="form-control" autocomplete="current-password" placeholder="Password" aria-required="true" />
                            <label asp-for="Input.Password"><i class="bi bi-lock-fill me-2"></i>Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="Input.RememberMe" class="form-check-input" />
                            <label asp-for="Input.RememberMe" class="form-check-label">
                                <i class="bi bi-check-circle me-2"></i>@Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-dark">
                            Log in <i class="bi bi-box-arrow-in-right ms-2"></i>
                        </button>

                        <div class="mt-3 text-center">
                            <p>
                                <a id="forgot-password" asp-page="./ForgotPassword" class="text-dark fw-bold">Forgot your password?</a>
                            </p>
                           
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <p>Don't have an account? <a asp-page="./Register" class="text-dark fw-bold">Register</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
