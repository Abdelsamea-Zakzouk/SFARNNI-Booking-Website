@page
@using myshop.Utilities
@model RegisterModel

@{
    ViewData["Title"] = "Register";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-dark text-white text-center">
                    <h3 class="card-title mb-0">@ViewData["Title"]</h3>
                    <p class="mt-2">Create a new account</p>
                </div>
                <div class="card-body">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="p-3">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.Name" class="form-control" autocomplete="username"
                                placeholder="John Doe" aria-required="true" />
                            <label asp-for="Input.Name"><i class="bi bi-person-fill me-2"></i>Name</label>
                            <span asp-validation-for="Input.Name" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username"
                                placeholder="name@example.com" aria-required="true" />
                            <label asp-for="Input.Email"><i class="bi bi-envelope me-2"></i>Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        
                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.City" class="form-control" autocomplete="username" placeholder="City"
                                aria-required="true" />
                            <label asp-for="Input.City"><i class="bi bi-geo-alt me-2"></i>City</label>
                            <span asp-validation-for="Input.City" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.Address" class="form-control" autocomplete="username"
                                placeholder="Address" aria-required="true" />
                            <label asp-for="Input.Address"><i class="bi bi-house-door-fill me-2"></i>Address</label>
                            <span asp-validation-for="Input.Address" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password"
                                placeholder="Password" aria-required="true" />
                            <label asp-for="Input.Password"><i class="bi bi-lock-fill me-2"></i>Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password"
                                placeholder="Confirm Password" aria-required="true" />
                            <label asp-for="Input.ConfirmPassword"><i class="bi bi-lock-fill me-2"></i>Confirm
                                Password</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        @if (User.IsInRole(SD.AdminRole))
                        {
                            <input type="radio" value="@SD.AdminRole" name="RoleRadio"> @SD.AdminRole
                            <input type="radio" value="@SD.EditorRole" name="RoleRadio"> @SD.EditorRole
                            <input type="radio" value="@SD.CustomerRole" name="RoleRadio"> @SD.CustomerRole
                        }

                        @if (User.IsInRole(SD.AdminRole))
                        {
                            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-dark">
                                Create <i class="bi bi-person-plus-fill ms-2"></i>
                            </button>
                        }
                        else
                        {
                            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-dark">
                                Register <i class="bi bi-person-plus-fill ms-2"></i>
                            </button>
                        }


    
                    </form>
                </div>
                @if (!User.IsInRole(SD.AdminRole))
                {
                    <div class="card-footer text-center py-3">
                        <p>Already have an account? <a asp-page="./Login" class="text-dark fw-bold">Log in</a></p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
