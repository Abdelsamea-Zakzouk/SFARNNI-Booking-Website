@{
    Layout = "~/Views/Shared/HomePage.cshtml";
}

<!--service start-->
<section id="service" class="service">
    <div class="container">

        <div class="service-counter text-center">

            <div class="col-md-4 col-sm-4" style="margin-right: 150px; margin-left: 100px;">
                <div class="single-service-box">

                    <div class="service-img">
                        <img src="LandingPage/assets/images/service/s2.png" alt="service-icon" />
                    </div><!--/.service-img-->
                    <div class="service-content">
                        <h2>
                            <a asp-area="Customer" asp-controller="Home" asp-action="Index">
                                book top class hotel
                            </a>
                        </h2>
                        <p>This amazing site helps you book the best hotels all around the world!</p>

                    </div><!--/.service-content-->
                </div><!--/.single-service-box-->
            </div><!--/.col-->
               


            <div class="col-md-4 col-sm-4">
                <div class="single-service-box">
                    <div class="statistics-img">
                        <img src="LandingPage/assets/images/service/s3.png" alt="service-icon" />
                    </div><!--/.service-img-->
                    <div class="service-content">

                        <h2>
                            <a asp-area="Flight" asp-controller="Home" asp-action="Index">
                                online flight booking
                            </a>
                        </h2>
                        <p>Book your flight instantly using TourNest!</p>
                    </div><!--/.service-content-->
                </div><!--/.single-service-box-->
            </div><!--/.col-->

        </div><!--/.statistics-counter-->
    </div><!--/.container-->

</section><!--/.service-->
<!--service end-->