@model HostHotelVM

<!DOCTYPE html>
<html lang="en">

<head>
    <title>Shopping Cart</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css">
    <link href=" https://fonts.googleapis.com/css?family=Montserrat" rel="stylesheet">
    <link rel="stylesheet" href="~/shoppingcart/style.css">
    <style>
        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #f8f9fa;
            color: #333;
        }

        .block-heading h2 {
            font-weight: 700;
            margin-bottom: 1rem;
            color: #007bff;
        }

        .shopping-cart {
            padding: 2rem 0;
        }

        .product {
            background: #fff;
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 1rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

            .product img {
                width: 100%;
                border-radius: 8px;
            }

        .product-name a {
            font-weight: 700;
            color: #007bff;
            text-decoration: none;
        }

        .product-info div {
            margin-top: 0.5rem;
            font-size: 0.9rem;
            color: #555;
        }

        .quantity .btn {
            font-size: 0.9rem;
        }

        .price {
            font-weight: bold;
            font-size: 1.1rem;
            color: #28a745;
        }

        .summary {
            background: #f8f9fa;
            padding: 1.5rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

            .summary h3 {
                font-weight: 700;
                margin-bottom: 1rem;
            }

        .summary-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .summary .btn-primary {
            background-color: #007bff;
            border: none;
            font-size: 1.1rem;
            padding: 0.75rem 1.5rem;
        }

        .btn-danger {
            font-size: 0.8rem;
        }
    </style>
</head>

<body>
    <main class="page">
        <section class="shopping-cart">
            <div class="container">
                <div class="block-heading text-center">
                    <h2>Shopping Cart</h2>
                </div>
                <div class="content">
                    <div class="row">
                        <!-- Cart Items -->
                        <div class="col-md-12 col-lg-8">
                            <div class="items">
                                @foreach (var item in Model.CartsList)
                                {
                                    <div class="product">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <img class="img-fluid mx-auto d-block image" src="~/@item.Product.Image" alt="Product Image">
                                            </div>
                                            <div class="col-md-8">
                                                <div class="info">
                                                    <div class="row">
                                                        <div class="col-md-7 product-name">
                                                            <a href="#">@item.Product.Name</a>
                                                            <div class="product-info">
                                                                <div>Description: <span class="value">@item.Product.Description</span></div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-5 text-right">
                                                            <label for="quantity">Quantity:</label>
                                                            <div class="btn-group">
                                                                <a class="btn btn-outline-primary" asp-action="Plus" asp-route-cartid="@item.Id">+</a>
                                                                <span class="mx-2">@item.Count</span>
                                                                <a class="btn btn-outline-primary" asp-action="Minus" asp-route-cartid="@item.Id">-</a>
                                                            </div>
                                                            <div class="price mt-2">$@item.Product.PricePerNight.ToString("F2")</div>
                                                        </div>
                                                    </div>
                                                    <div class="mt-3 text-right">
                                                        <a asp-action="Remove" asp-route-cartid="@item.Id" class="btn btn-danger">Remove</a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Summary Section -->
                        <div class="col-md-12 col-lg-4">
                            <div class="summary">
                                <h3>Order Summary</h3>
                                <div class="summary-item">
                                    <span>Total:</span>
                                    <span class="price">$@Model.TotalCarts.ToString("F2")</span>
                                </div>
                                <a href="~/Customer/Cart/Summary" class="btn btn-primary btn-lg btn-block">Checkout</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>

</html>





